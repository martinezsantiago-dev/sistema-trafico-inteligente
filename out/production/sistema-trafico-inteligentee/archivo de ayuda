Ejemplo arbol

package tda;

import tda.interfaces.IArbolNario;

public class ArbolNario<T> implements IArbolNario<T> {

    private NodoArbolNario<T> raiz;
    private int cantidad;

    public ArbolNario() {
        this.raiz = null;
        this.cantidad = 0;
    }

    @Override
    public boolean estaVacio() {
        return raiz == null;
    }

    @Override
    public void crearRaiz(T dato) {
        if (raiz == null) {
            raiz = new NodoArbolNario<>(dato);
            cantidad = 1;
        }
    }

    @Override
    public boolean agregarHijo(T datoPadre, T datoHijo) {
        if (estaVacio()) {
            return false;
        }

        NodoArbolNario<T> padre = buscarNodo(raiz, datoPadre);

        if (padre == null) {
            return false;
        }

        NodoArbolNario<T> nuevoHijo = new NodoArbolNario<>(datoHijo);
        padre.agregarHijo(nuevoHijo);
        cantidad++;

        return true;
    }

    @Override
    public boolean buscar(T dato) {
        return buscarNodo(raiz, dato) != null;
    }

    private NodoArbolNario<T> buscarNodo(NodoArbolNario<T> actual, T datoBuscado) {
        if (actual == null) {
            return null;
        }

        if (sonIguales(actual.dato, datoBuscado)) {
            return actual;
        }

        Nodo<NodoArbolNario<T>> aux = actual.hijos.getCabeza();

        while (aux != null) {
            NodoArbolNario<T> encontrado = buscarNodo(aux.dato, datoBuscado);

            if (encontrado != null) {
                return encontrado;
            }

            aux = aux.siguiente;
        }

        return null;
    }

    private boolean sonIguales(T a, T b) {
        if (a == null && b == null) {
            return true;
        }

        if (a == null || b == null) {
            return false;
        }

        return a.equals(b);
    }

    @Override
    public int tamanio() {
        return cantidad;
    }

    @Override
    public int altura() {
        return alturaRecursiva(raiz);
    }

    private int alturaRecursiva(NodoArbolNario<T> actual) {
        if (actual == null) {
            return 0;
        }

        int mayorAlturaHijo = 0;

        Nodo<NodoArbolNario<T>> aux = actual.hijos.getCabeza();

        while (aux != null) {
            int alturaHijo = alturaRecursiva(aux.dato);

            if (alturaHijo > mayorAlturaHijo) {
                mayorAlturaHijo = alturaHijo;
            }

            aux = aux.siguiente;
        }

        return mayorAlturaHijo + 1;
    }

    @Override
    public void mostrar() {
        if (estaVacio()) {
            System.out.println("El árbol está vacío");
            return;
        }

        mostrarRecursivo(raiz, 0);
    }

    private void mostrarRecursivo(NodoArbolNario<T> actual, int nivel) {
        if (actual == null) {
            return;
        }

        for (int i = 0; i < nivel; i++) {
            System.out.print("   ");
        }

        System.out.println("- " + actual.dato);

        Nodo<NodoArbolNario<T>> aux = actual.hijos.getCabeza();

        while (aux != null) {
            mostrarRecursivo(aux.dato, nivel + 1);
            aux = aux.siguiente;
        }
    }
}